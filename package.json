{
  "name": "dany-tech-alquimia",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite dev",
    "dev:auto": "npm install && vite dev",
    "build": "vite build && tsc --noEmit",
